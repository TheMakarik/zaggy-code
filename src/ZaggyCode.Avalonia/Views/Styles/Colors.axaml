<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core purple dark palette -->
    <Color x:Key="BackgroundColor">#16101E</Color>
    <Color x:Key="BackgroundSecondaryColor">#1E1528</Color>
    <Color x:Key="SurfaceColor">#251D30</Color>
    <Color x:Key="SurfaceLightColor">#2E243D</Color>
    <Color x:Key="SurfaceHoverColor">#382C4A</Color>

    <Color x:Key="PrimaryColor">#B07CFF</Color>
    <Color x:Key="PrimaryLightColor">#D1A8FF</Color>
    <Color x:Key="PrimaryDarkColor">#8A5ECC</Color>

    <Color x:Key="ForegroundColor">#F2F0F5</Color>
    <Color x:Key="ForegroundMutedColor">#A99FB8</Color>
    <Color x:Key="ForegroundDarkColor">#6B5F7A</Color>

    <Color x:Key="BorderColor">#3A2F4A</Color>
    <Color x:Key="BorderLightColor">#4D3F61</Color>

    <!-- Semantic colors -->
    <Color x:Key="SuccessColor">#4ADE80</Color>
    <Color x:Key="SuccessDarkColor">#22C55E</Color>
    <Color x:Key="ErrorColor">#F87171</Color>
    <Color x:Key="WarningColor">#FACC15</Color>

    <!-- Component specific colors -->
    <Color x:Key="EditorBackgroundColor">#1A1322</Color>
    <Color x:Key="EditorForegroundColor">#F2F0F5</Color>
    <Color x:Key="EditorLineNumberColor">#6B5F7A</Color>

    <Color x:Key="TerminalBackgroundColor">#16101E</Color>
    <Color x:Key="TerminalForegroundColor">#F2F0F5</Color>

    <Color x:Key="SidebarBackgroundColor">#1E1528</Color>

    <!-- Accent override for FluentTheme -->
    <Color x:Key="SystemAccentColor">#B07CFF</Color>
    <Color x:Key="SystemAccentColorLight1">#D1A8FF</Color>
    <Color x:Key="SystemAccentColorDark1">#8A5ECC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />

    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" />
    <SolidColorBrush x:Key="ForegroundMutedBrush" Color="{StaticResource ForegroundMutedColor}" />
    <SolidColorBrush x:Key="ForegroundDarkBrush" Color="{StaticResource ForegroundDarkColor}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDarkColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="{StaticResource EditorBackgroundColor}" />
    <SolidColorBrush x:Key="EditorForegroundBrush" Color="{StaticResource EditorForegroundColor}" />
    <SolidColorBrush x:Key="EditorLineNumberBrush" Color="{StaticResource EditorLineNumberColor}" />

    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="{StaticResource TerminalBackgroundColor}" />
    <SolidColorBrush x:Key="TerminalForegroundBrush" Color="{StaticResource TerminalForegroundColor}" />

    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" />

</ResourceDictionary>

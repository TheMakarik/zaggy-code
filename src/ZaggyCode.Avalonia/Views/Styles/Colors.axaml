<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BackgroundColor">#1A1A1A</Color>
    <Color x:Key="BackgroundSecondaryColor">#242424</Color>
    <Color x:Key="SurfaceColor">#2E2E2E</Color>
    <Color x:Key="SurfaceLightColor">#383838</Color>
    <Color x:Key="SurfaceHoverColor">#444444</Color>

    <Color x:Key="PrimaryColor">#7A8A9A</Color>
    <Color x:Key="PrimaryLightColor">#9AACBC</Color>
    <Color x:Key="PrimaryDarkColor">#5A6A7A</Color>

    <Color x:Key="ForegroundColor">#F0F0F0</Color>
    <Color x:Key="ForegroundMutedColor">#A8A8A8</Color>
    <Color x:Key="ForegroundDarkColor">#707070</Color>

    <Color x:Key="BorderColor">#3D3D3D</Color>
    <Color x:Key="BorderLightColor">#505050</Color>

    <Color x:Key="SuccessColor">#6ABA6A</Color>
    <Color x:Key="SuccessDarkColor">#4AA84A</Color>
    <Color x:Key="ErrorColor">#D87060</Color>
    <Color x:Key="WarningColor">#E8B840</Color>

    <Color x:Key="EditorBackgroundColor">#161616</Color>
    <Color x:Key="EditorForegroundColor">#F0F0F0</Color>
    <Color x:Key="EditorLineNumberColor">#707070</Color>

    <Color x:Key="TerminalBackgroundColor">#1A1A1A</Color>
    <Color x:Key="TerminalForegroundColor">#F0F0F0</Color>

    <Color x:Key="SidebarBackgroundColor">#242424</Color>

    <Color x:Key="SystemAccentColor">#7A8A9A</Color>
    <Color x:Key="SystemAccentColorLight1">#9AACBC</Color>
    <Color x:Key="SystemAccentColorDark1">#5A6A7A</Color>

    <SolidColorBrush Color="{StaticResource BackgroundColor}" x:Key="BackgroundBrush" />
    <SolidColorBrush Color="{StaticResource BackgroundSecondaryColor}" x:Key="BackgroundSecondaryBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceColor}" x:Key="SurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceLightColor}" x:Key="SurfaceLightBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceHoverColor}" x:Key="SurfaceHoverBrush" />

    <SolidColorBrush Color="{StaticResource PrimaryColor}" x:Key="PrimaryBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryLightColor}" x:Key="PrimaryLightBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryDarkColor}" x:Key="PrimaryDarkBrush" />

    <SolidColorBrush Color="{StaticResource ForegroundColor}" x:Key="ForegroundBrush" />
    <SolidColorBrush Color="{StaticResource ForegroundMutedColor}" x:Key="ForegroundMutedBrush" />
    <SolidColorBrush Color="{StaticResource ForegroundDarkColor}" x:Key="ForegroundDarkBrush" />

    <SolidColorBrush Color="{StaticResource BorderColor}" x:Key="BorderBrush" />
    <SolidColorBrush Color="{StaticResource BorderLightColor}" x:Key="BorderLightBrush" />

    <SolidColorBrush Color="{StaticResource SuccessColor}" x:Key="SuccessBrush" />
    <SolidColorBrush Color="{StaticResource SuccessDarkColor}" x:Key="SuccessDarkBrush" />
    <SolidColorBrush Color="{StaticResource ErrorColor}" x:Key="ErrorBrush" />
    <SolidColorBrush Color="{StaticResource WarningColor}" x:Key="WarningBrush" />

    <SolidColorBrush Color="{StaticResource EditorBackgroundColor}" x:Key="EditorBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource EditorForegroundColor}" x:Key="EditorForegroundBrush" />
    <SolidColorBrush Color="{StaticResource EditorLineNumberColor}" x:Key="EditorLineNumberBrush" />

    <SolidColorBrush Color="{StaticResource TerminalBackgroundColor}" x:Key="TerminalBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource TerminalForegroundColor}" x:Key="TerminalForegroundBrush" />

    <SolidColorBrush Color="{StaticResource SidebarBackgroundColor}" x:Key="SidebarBackgroundBrush" />

</ResourceDictionary>
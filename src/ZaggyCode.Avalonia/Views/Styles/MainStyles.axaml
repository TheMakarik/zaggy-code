<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
    xmlns:conv="using:Avalonia.Controls.Converters"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Views/Styles/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
            <CornerRadius x:Key="SmallCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
            <Thickness x:Key="CardPadding">12</Thickness>

            <conv:PlatformKeyGestureConverter x:Key="KeyGestureConverter" />
            <StreamGeometry x:Key="MenuItemChevronPathData">M 1,0 10,10 l -9,10 -1,-1 L 8,10 -0,1 Z</StreamGeometry>

            <ControlTheme x:Key="ZaggyMenuItemIconTheme" TargetType="ContentControl">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Template">
                    <ControlTemplate>
                        <Viewbox
                            HorizontalAlignment="Center"
                            StretchDirection="DownOnly"
                            VerticalAlignment="Center">
                            <ContentPresenter x:Name="PART_ContentPresenter" Content="{TemplateBinding Content}" />
                        </Viewbox>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <!-- Nested MenuItem (submenu items) -->
            <ControlTheme x:Key="{x:Type MenuItem}" TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
                <Setter Property="Template">
                    <ControlTemplate>
                        <Panel>
                            <Border
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Name="PART_LayoutRoot"
                                Padding="{TemplateBinding Padding}">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <ContentControl
                                        Content="{TemplateBinding Icon}"
                                        Grid.Column="0"
                                        IsVisible="False"
                                        Margin="0,0,10,0"
                                        Name="PART_IconPresenter"
                                        Theme="{StaticResource ZaggyMenuItemIconTheme}" />
                                    <ContentPresenter
                                        Content="{TemplateBinding Header}"
                                        ContentTemplate="{TemplateBinding HeaderTemplate}"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Name="PART_HeaderPresenter"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Foreground="{DynamicResource ForegroundMutedBrush}"
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        Margin="12,0,0,0"
                                        Name="PART_InputGestureText"
                                        Text="{TemplateBinding InputGesture, Converter={StaticResource KeyGestureConverter}}"
                                        VerticalAlignment="Center" />
                                    <Path
                                        Data="{StaticResource MenuItemChevronPathData}"
                                        Fill="{DynamicResource ForegroundMutedBrush}"
                                        Grid.Column="3"
                                        Height="10"
                                        Margin="8,0,0,0"
                                        Name="PART_ChevronPath"
                                        Stretch="Uniform"
                                        VerticalAlignment="Center"
                                        Width="7" />
                                </Grid>
                            </Border>
                            <Popup
                                HorizontalOffset="-4"
                                IsLightDismissEnabled="False"
                                IsOpen="{TemplateBinding IsSubMenuOpen, Mode=TwoWay}"
                                Name="PART_Popup"
                                Placement="RightEdgeAlignedTop"
                                WindowManagerAddShadowHint="False">
                                <Border
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource SmallCornerRadius}"
                                    Padding="0">
                                    <ScrollViewer Theme="{StaticResource FluentMenuScrollViewer}">
                                        <ItemsPresenter
                                            Grid.IsSharedSizeScope="True"
                                            ItemsPanel="{TemplateBinding ItemsPanel}"
                                            Margin="0"
                                            Name="PART_ItemsPresenter" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>
                    </ControlTemplate>
                </Setter>

                <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
                    <Setter Property="RecognizesAccessKey" Value="True" />
                </Style>

                <Style Selector="^:icon /template/ ContentControl#PART_IconPresenter">
                    <Setter Property="IsVisible" Value="True" />
                </Style>

                <Style Selector="^:selected">
                    <Style Selector="^ /template/ Border#PART_LayoutRoot">
                        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                    </Style>
                    <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryLightBrush}" />
                    </Style>
                    <Style Selector="^ /template/ Path#PART_ChevronPath">
                        <Setter Property="Fill" Value="{DynamicResource PrimaryLightBrush}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
                </Style>

                <Style Selector="^:disabled">
                    <Style Selector="^ /template/ Border#PART_LayoutRoot">
                        <Setter Property="Opacity" Value="0.5" />
                    </Style>
                </Style>

                <Style Selector="^:open /template/ Path#PART_ChevronPath">
                    <Setter Property="Fill" Value="{DynamicResource PrimaryLightBrush}" />
                </Style>

                <Style Selector="^:empty /template/ Path#PART_ChevronPath">
                    <Setter Property="IsVisible" Value="False" />
                </Style>

                <Style Selector="^:separator">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Separator />
                        </ControlTemplate>
                    </Setter>
                </Style>
            </ControlTheme>

            <!-- Top-level MenuItem (menu bar items) -->
            <ControlTheme x:Key="ZaggyTopLevelMenuItem" TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Name="PART_LayoutRoot">
                            <Panel>
                                <Grid ColumnDefinitions="Auto,Auto,*" Margin="{TemplateBinding Padding}">
                                    <ContentControl
                                        Content="{TemplateBinding Icon}"
                                        Grid.Column="0"
                                        IsVisible="False"
                                        Margin="0,0,8,0"
                                        Name="PART_IconPresenter"
                                        Theme="{StaticResource ZaggyMenuItemIconTheme}" />
                                    <ContentPresenter
                                        Content="{TemplateBinding Header}"
                                        ContentTemplate="{TemplateBinding HeaderTemplate}"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Name="PART_HeaderPresenter"
                                        VerticalAlignment="Center" />
                                </Grid>
                                <Popup
                                    IsLightDismissEnabled="True"
                                    IsOpen="{TemplateBinding IsSubMenuOpen, Mode=TwoWay}"
                                    MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Name="PART_Popup"
                                    OverlayInputPassThroughElement="{Binding $parent[Menu]}"
                                    Placement="BottomEdgeAlignedLeft"
                                    WindowManagerAddShadowHint="False">
                                    <Border
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource SmallCornerRadius}"
                                        Padding="0">
                                        <ScrollViewer Theme="{StaticResource FluentMenuScrollViewer}">
                                            <ItemsPresenter
                                                Grid.IsSharedSizeScope="True"
                                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                                Margin="0"
                                                Name="PART_ItemsPresenter" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Panel>
                        </Border>
                    </ControlTemplate>
                </Setter>

                <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
                    <Setter Property="RecognizesAccessKey" Value="True" />
                </Style>

                <Style Selector="^:icon /template/ ContentControl#PART_IconPresenter">
                    <Setter Property="IsVisible" Value="True" />
                </Style>

                <Style Selector="^:selected">
                    <Style Selector="^ /template/ Border#PART_LayoutRoot">
                        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                    </Style>
                    <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryLightBrush}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
                </Style>

                <Style Selector="^:disabled">
                    <Style Selector="^ /template/ Border#PART_LayoutRoot">
                        <Setter Property="Opacity" Value="0.5" />
                    </Style>
                </Style>
            </ControlTheme>

            <!-- Menu -->
            <ControlTheme x:Key="{x:Type Menu}" TargetType="Menu">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="ItemContainerTheme" Value="{StaticResource ZaggyTopLevelMenuItem}" />
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            HorizontalAlignment="Stretch"
                            Padding="{TemplateBinding Padding}">
                            <ItemsPresenter
                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                KeyboardNavigation.TabNavigation="Continue"
                                Name="PART_ItemsPresenter"
                                VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Window base -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <!-- Panels and general backgrounds -->
    <Style Selector="Grid.main-background">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
    </Style>

    <Style Selector="Grid.sidebar">
        <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}" />
    </Style>

    <!-- Generic text -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
    </Style>

    <Style Selector="Label">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <!-- Cards / surfaces -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
    </Style>

    <Style Selector="Border.header-bar">
        <Setter Property="Background" Value="{DynamicResource BackgroundSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.terminal-header">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="10,10,0,0" />
    </Style>

    <!-- Icon buttons (sidebar / header) -->
    <Style Selector="Button.icon-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.icon-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryLightBrush}" />
    </Style>

    <Style Selector="Button.icon-button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
    </Style>

    <Style Selector="Button.icon-button materialIcons|MaterialIcon">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
    </Style>

    <!-- Run button (green accent, no border) -->
    <Style Selector="Button.run-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style Selector="Button.run-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SuccessDarkBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}" />
    </Style>

    <Style Selector="Button.run-button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
    </Style>

    <Style Selector="Button.run-button materialIcons|MaterialIcon">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
    </Style>

    <!-- Window control buttons (terminal header) -->
    <Style Selector="Button.window-control">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.window-control:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="Button.window-control.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <!-- Full integrated menu bar -->
    <Style Selector="Menu.full-menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Menu.full-menu > MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
    </Style>

    <!-- Compact hamburger menu -->
    <Style Selector="Menu.compact-menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Menu.compact-menu > MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
    </Style>

    <!-- Language selector -->
    <Style Selector="ComboBox.language-selector">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Width" Value="130" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ComboBox.language-selector:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>

    <Style Selector="ComboBox.language-selector > ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="ComboBox.language-selector > ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
    </Style>

    <!-- Execution speed button -->
    <Style Selector="Button.speed-button">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryLightBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="Width" Value="50" />
        <Setter Property="Height" Value="28" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.speed-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="Button.speed-flyout-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinWidth" Value="50" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.speed-flyout-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryLightBrush}" />
    </Style>

    <Style Selector="FlyoutPresenter.speed-flyout-presenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="FlyoutPresenter.speed-flyout-presenter /template/ Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- AvaloniaEdit -->
    <Style Selector="avaloniaEdit|TextEditor">
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource EditorForegroundBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,Monospace" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="avaloniaEdit|TextEditor /template/ Border">
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
    </Style>

    <!-- Grid splitters -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Invisible splitter between editor and game/preview -->
    <Style Selector="GridSplitter.subtle">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="4" />
        <Setter Property="Cursor" Value="SizeWestEast" />
    </Style>

    <!-- Prominent splitter between terminal and upper grid -->
    <Style Selector="GridSplitter.horizontal">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Cursor" Value="SizeNorthSouth" />
    </Style>

    <Style Selector="GridSplitter.horizontal:pointerover">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <!-- ToolTip -->
    <Style Selector="ToolTip">
        <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource SmallCornerRadius}" />
    </Style>

</Styles>

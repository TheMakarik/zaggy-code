{
   "StorageOptions": {
     "GameCodeDataPath": "/zaggy/game-code",
     "DataFilePath": "/zaggy/data.json",
     "WaitUserDataUpdateSeconds": 3
   },
  "DefaultUser": {
    "User": {
      "EnableCodeHighlighting": true,
      "ShowCodeLineNumbers": true,
      "CodeFontSize": 14,
      "TerminalFontSize": 18,
      "CodeTheme": "Light",
      "LastLanguage": "Lua",
      "LastGamePath": null,
      "LastSpeed": "X2",
      "LuaData": {
        "MaxRecursion": 2000,
        "UseTableContentCheckerByDefault": true
      }
    }
  },
  
 "FontSizeOptions": {
   "MaxFontSize": 30,
   "MinFontSize": 10
 },

  "LuaPathsOptions": {
    "RegisterIoLuaPath": "Languages/Lua/RegisterIORedirect.lua",
    "RegisterIncorrectlyWroteNameCheckerLuaPath": "Languages/Lua/RegisterIncorrentWriteNameChecker.lua",
    "RegisterRobotLuaPath": "Languages/Lua/RegisterRobot.lua",
    "SetNewLikeHookPath": "Languages/Lua/SetNewLineHook.lua"
  },
  
  "SpeedMillisecondsOptions": {
    "X1": 1000,
    "X2": 500,
    "X5": 200,
    "X10": 100,
    "X20": 50,
    "SleepChunk": 50
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Settings.Configuration"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Debug"
      }
    },
    "Enrich": [
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm}] [{Level}] [Thread:{ThreadId}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}